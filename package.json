{
  "name": "place",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/maybe-migrate.mjs && cross-env NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:ui": "vitest run --project ui",
    "test:coverage": "cross-env COVERAGE=1 vitest run --coverage",
    "e2e": "node scripts/ensure-e2e-cert.mjs && playwright test",
    "e2e:ui": "node scripts/ensure-e2e-cert.mjs && playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node scripts/db-seed.mjs",
    "analyze": "cross-env ANALYZE=true NODE_ENV=production next build",
    "lhci": "lhci autorun",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@neondatabase/auth": "0.4.1-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/nextjs": "^10.55.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.185",
    "drizzle-orm": "^0.45.2",
    "iconoir-react": "^7.11.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.1.6",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ]
  }
}
