# place — Environment variables example
#
# Copy this file to .env.local (gitignored) and fill in the values.
# Variables marked PROD-ONLY should ONLY exist in Vercel (production env scope),
# never in .env.local or in preview/dev environments.
#
# Reference canon: docs/stack.md §"Variables de entorno" + ADR-0004 (Drizzle +
# Neon roles) + ADR-0017 (production-only migrations via maybe-migrate.mjs) +
# ADR-0032 (Custom Domain SSO Signed Ticket).

# =============================================================================
# Database — Neon (PostgreSQL serverless)
# =============================================================================

# Pooled connection string, rol `app_system` (NO-admin, NO BYPASSRLS).
# Lo usa el runtime de la app — RLS aplica per query.
# Where: Neon Dashboard → tu project → Connection Details → role: app_system.
DATABASE_URL=postgresql://app_system:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Admin connection string, rol `neondb_owner` (con BYPASSRLS).
# SOLO para `pnpm db:migrate` (drizzle-kit). NUNCA en runtime de la app.
# PROD scope: setear en Vercel production only (validated en maybe-migrate.mjs).
# Where: Neon Dashboard → role: neondb_owner.
DATABASE_URL_MIGRATE=postgresql://neondb_owner:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Test branch (Neon ephemeral o dedicated). Mismo project, branch separado.
# Local: opcional (tests integration corren sin esto, skip al inicio).
# CI: REQUERIDO — secrets en GitHub Actions (ver .github/workflows/tests.yml).
DATABASE_URL_TEST=postgresql://app_system:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL_TEST_MIGRATE=postgresql://neondb_owner:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# =============================================================================
# Neon Auth (Better Auth)
# =============================================================================

# Base URL del SDK Neon Auth (apex donde vive el manejo de identidad).
# Local: http://localhost:3000 ; Prod: https://place.community
NEON_AUTH_BASE_URL=http://localhost:3000

# JWKS endpoint del SDK (usado para verificar JWTs server-side).
# Por convención: ${NEON_AUTH_BASE_URL}/api/auth/jwks.
NEON_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks

# Cookie secret para firmar la cookie de sesión Neon Auth (mín 32 chars).
# Generación: `openssl rand -base64 48`. NUNCA reusar entre environments.
NEON_AUTH_COOKIE_SECRET=GENERATE_WITH_openssl_rand_base64_48

# =============================================================================
# App (públicas — NEXT_PUBLIC_*)
# =============================================================================

# URL apex pública del proyecto. Local: http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dominio apex (sin scheme). Usado por multi-tenancy resolver +
# rootDomain() helpers. Local: localhost ; Prod: place.community.
NEXT_PUBLIC_APP_DOMAIN=localhost

# =============================================================================
# Vercel Domains API (custom domains feature)
# =============================================================================
# Consumidas por src/shared/lib/vercel/domains.ts (ADR-0026, feature
# custom-domain V1: addDomain/getDomainStatus/removeDomain). Sin estas dos
# en Vercel env, el wrapper retorna `vercel_error` (defensivo, no crash);
# en dev local sin tokens el slice /settings/domain no opera (degrada).

# Vercel API token con scope `domains:write` para el team.
# Where: Vercel Dashboard → Account Settings → Tokens → Create.
# PROD-ONLY recomendado (limitar blast radius).
VERCEL_API_TOKEN=

# ID del proyecto Vercel (encontrarlo en .vercel/project.json o Dashboard).
VERCEL_PROJECT_ID=

# Inyectado AUTO por Vercel runtime (no setear manualmente).
# Valores: "production" | "preview" | "development".
# Usado por scripts/maybe-migrate.mjs para gate prod-only migrations.
# VERCEL_ENV=  # NO setear — Vercel lo provee.

# =============================================================================
# Custom Domain SSO (Feature C, ADR-0032)
# =============================================================================
# Vercel-only, NUNCA en .env.local committed. Consumidas por
# src/shared/lib/sso/sso-keys.ts. Setear en Vercel para production + preview
# environments (preview branches del PR pipeline necesitan testear el flow).
#
# Generación de la signing key (ES256 PKCS8):
#   openssl ecparam -name prime256v1 -genkey -noout -out tmp.pem
#   openssl pkcs8 -topk8 -nocrypt -in tmp.pem -out signing-pkcs8.pem
#   # (contenido de signing-pkcs8.pem → Vercel env var multiline)
#   rm tmp.pem signing-pkcs8.pem
#
# Rotación operacional V1: manual cada 90 días (downtime ≤60s = TTL ticket).
# V2 multi-key rotation (zero-downtime) diferido.

PLACE_SSO_SIGNING_KEY=    # ES256 PKCS8 PEM private key (multiline)
PLACE_SSO_SIGNING_KEY_KID=  # short string, ej. "2026-05-23-r1"

# =============================================================================
# Planned (NO usadas en código actual — gated para V1.3+)
# =============================================================================

# Email transaccional (Resend) — Planned para V1.3 lifecycle (ADR-0003 emails:
# verificación de email, avisos d0/+2/+7 lifecycle, etc.). HOY no consumido
# por código. Setear el día que se active el slice de email.
RESEND_API_KEY=

# Vercel AI Gateway (Vercel AI SDK lee este env var internamente, NO via
# process.env explícito en código). Habilita slice `style-assist/` (ADR-0007,
# actualmente dormido por ADR-0020). Setear cuando se reactive el slice.
AI_GATEWAY_API_KEY=
